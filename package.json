{
  "name": "lior",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "vite --config vite.admin.config.ts",
    "build": "vite build",
    "build:admin": "vite build --config vite.admin.config.ts",
    "preview": "vite preview",
    "preview:admin": "vite preview --config vite.admin.config.ts --outDir dist-admin",
    "brain:build": "python scripts/graphify_second_brain.py",
    "brain:watch": "python scripts/graphify_second_brain.py --watch",
    "test": "node tests/run-assertions.mjs",
    "typecheck": "npm run typecheck:app && npm run typecheck:supabase",
    "typecheck:app": "npx tsc --noEmit -p tsconfig.json",
    "typecheck:supabase": "npx tsc --noEmit -p tsconfig.supabase.json"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.12"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/supabase-js": "^2.89.0",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.0",
    "graphify": "^1.0.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.562.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^8.0.8"
  }
}
