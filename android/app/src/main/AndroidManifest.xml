<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Predictive back stays OFF: the app drives its own in-app back stack
         through Capacitor's backButton listener, which relies on the legacy
         onBackPressed dispatch. Enabling onBackInvokedCallback would bypass
         that listener on Android 13+ and back would background the app. -->
    <application
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:windowSoftInputMode="adjustNothing">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth deep-link return URL. After Google sign-in completes,
                 Supabase redirects to com.lior.app://auth/callback?code=…
                 and Android delivers that intent to MainActivity. The
                 Capacitor App plugin's appUrlOpen listener then hands the
                 URL to Supabase for the PKCE code exchange. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.lior.app" android:host="auth" />
            </intent-filter>

            <!-- Launcher shortcut deep links: com.lior.app://shortcut/<view> -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.lior.app" android:host="shortcut" />
            </intent-filter>

            <!-- Pair-invite deep links: com.lior.app://claim?code=<8-char-code>
                 A tapped partner invite delivers the pairing code to
                 MainActivity. The Capacitor App plugin's appUrlOpen listener
                 (see App.tsx) parses the code and routes into the claim flow. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.lior.app" android:host="claim" />
            </intent-filter>

            <!-- Share target: photos shared from the gallery (or any app)
                 land in Add Memory. Handled by ShareTargetPlugin. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />

        </activity>

        <!-- FCM defaults: when a remote push arrives while the app is
             backgrounded/killed, FirebaseMessagingService renders it natively.
             Without these it falls back to the launcher icon (renders as a white
             square once Android alpha-masks it) on the default channel (no
             heads-up). Wire it to our silhouette icon, brand tint and the
             high-importance 'lior-reminders' channel. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/lior_notification_color" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="lior-reminders" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Camera and Gallery -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Push Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Local notifications: inexact, Doze-friendly delivery + survive reboot.
         Deliberately NOT requesting SCHEDULE_EXACT_ALARM / USE_EXACT_ALARM:
         daily relationship nudges don't need to-the-second timing, and
         USE_EXACT_ALARM is a Play "special use" permission reserved for
         alarm/clock/calendar apps (requires a special-access declaration and is
         rejected otherwise). The notification scheduler keeps allowWhileIdle so
         delivery still fires during Doze, just without exact-alarm scheduling. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Wake lock for background sync -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
</manifest>
