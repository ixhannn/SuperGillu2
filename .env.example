# Copy this file to .env.local and fill in your values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# ── Native Google Sign-In (Android/iOS) ──────────────────────────────
# OAuth 2.0 "Web application" client ID from Google Cloud Console
# (NOT the Android client ID). Used by the native Credential Manager account
# picker AND validated by Supabase when verifying the returned ID token, so it
# must be in the Supabase Google provider's "Authorized Client IDs".
# Public by design (ships in the app).
# NOTE: this lives in the SIGN-IN Google project 220998279719 — NOT the Firebase
# push project (lior-bf6e6 / 372560896422). google-services.json is push-only.
VITE_GOOGLE_WEB_CLIENT_ID=220998279719-xxxxxxxxxxxx.apps.googleusercontent.com

# Server-side AI secret:
# Set GEMINI_API_KEY in Supabase Edge Function secrets for `pet-dialogue`.
# Do not expose it via a VITE_ variable.
GEMINI_API_KEY=your_server_side_gemini_api_key_here

# Cloudflare R2 media storage (via Worker proxy)
# See cloudflare/wrangler.toml for deployment instructions.
# Client writes are authenticated with the current Supabase session.
VITE_R2_WORKER_URL=https://lior-media.your-subdomain.workers.dev

# ── Push Notifications ───────────────────────────────────────────────
# VAPID keys for PWA web push (generate with: npx web-push generate-vapid-keys)
# The public key is exposed client-side; the private key stays on the server.
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Set these in Supabase Edge Function secrets (NOT here):
#   VAPID_PUBLIC_KEY   — public VAPID key (same value as VITE_VAPID_PUBLIC_KEY above).
#                        Required by RFC 8292: sent as the `k=` Authorization param.
#   VAPID_PRIVATE_KEY  — private VAPID key for web push
#   VAPID_CONTACT      — mailto: or https: contact URL (required by web-push spec)
#   FCM_SERVER_KEY     — Firebase Cloud Messaging server key
#                        Firebase console → Project Settings → Cloud Messaging → Server key
#
# Firebase setup for Android native push:
#   1. Create project at https://console.firebase.google.com
#   2. Add Android app (com.lior.app)
#   3. Download google-services.json → place at android/app/google-services.json
#   4. Copy the Server key → set FCM_SERVER_KEY in Supabase Edge Function secrets

# ── Product analytics + crash reporting (ALL OPTIONAL) ───────────────────────
# The app is a complete no-op without these — leave them blank to ship with only
# the first-party app_events ledger (Supabase) and no third-party telemetry.
#
# PostHog product analytics (funnels / retention / cohorts). Create a project at
# posthog.com and use the "Project API Key" (public, ships in the app). Set HOST
# to your PostHog cloud region (or a reverse-proxy domain). Autocapture, session
# replay and pageviews are disabled in code — only the 6 named events are sent.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
#   EU region users: https://eu.i.posthog.com
#
# Sentry crash / error monitoring. DSN from Sentry → Project Settings → Client
# Keys (public, ships in the app). Leave blank to disable Sentry entirely.
# NOTE: adding either of these means the privacy policy's "no analytics / no
# third-party crash-reporting" line must be reworded, and the Play Data Safety
# form updated to declare PostHog / Sentry as data recipients.
VITE_SENTRY_DSN=
