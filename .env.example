# Copy this file to .env.local and fill in your values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# Server-side AI secret:
# Set GEMINI_API_KEY in Supabase Edge Function secrets for `pet-dialogue`.
# Do not expose it via a VITE_ variable.
GEMINI_API_KEY=your_server_side_gemini_api_key_here

# Cloudflare R2 media storage (via Worker proxy)
# See cloudflare/wrangler.toml for deployment instructions.
# Client writes are authenticated with the current Supabase session.
VITE_R2_WORKER_URL=https://lior-media.your-subdomain.workers.dev
