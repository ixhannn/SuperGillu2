# Copy this file to .env.local and fill in your values
GEMINI_API_KEY=your_gemini_api_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# Cloudflare R2 media storage (via Worker proxy)
# See cloudflare/wrangler.toml for deployment instructions
VITE_R2_WORKER_URL=https://lior-media.your-subdomain.workers.dev
VITE_R2_UPLOAD_KEY=your_upload_secret_here
